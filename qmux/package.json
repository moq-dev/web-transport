{
	"name": "@moq/qmux",
	"author": "Luke Curley <kixelated@gmail.com>",
	"version": "0.0.1",
	"description": "QMux protocol (draft-ietf-quic-qmux-00) over WebSockets",
	"type": "module",
	"license": "(MIT OR Apache-2.0)",
	"repository": "github:moq-dev/web-transport",
	"exports": {
		".": "./src/index.ts"
	},
	"types": "./src/index.ts",
	"files": [
		"./src"
	],
	"scripts": {
		"build": "rimraf dist && tsc && tsx scripts/package.ts",
		"dev": "tsc --watch",
		"check": "tsc --noEmit",
		"example": "tsx examples/client.ts",
		"release": "tsx scripts/release.ts"
	},
	"devDependencies": {
		"typescript": "^5.9.2",
		"rimraf": "^6.0.1",
		"@types/node": "^24.3.0",
		"tsx": "^4.20.5"
	},
	"keywords": [
		"qmux",
		"webtransport",
		"websocket",
		"polyfill",
		"quic",
		"streams"
	]
}
