{
	"name": "@moq/qmux",
	"author": "Luke Curley <kixelated@gmail.com>",
	"version": "0.2.0",
	"description": "QMux protocol (draft-ietf-quic-qmux-02) over WebSockets",
	"type": "module",
	"license": "(MIT OR Apache-2.0)",
	"repository": "github:moq-dev/web-transport",
	"exports": {
		".": "./src/index.ts"
	},
	"types": "./src/index.ts",
	"files": [
		"./src"
	],
	"dependencies": {
		"@moq/web-socket-stream": "workspace:*"
	},
	"scripts": {
		"build": "rimraf dist && tsc && tsx ../common/package.ts",
		"dev": "tsc --watch",
		"check": "tsc --noEmit",
		"example": "tsx examples/client.ts",
		"release": "bun ../common/release.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^26.1.0",
		"rimraf": "^6.1.3",
		"tsx": "^4.23.0",
		"typescript": "7.0.1-rc"
	},
	"keywords": [
		"qmux",
		"webtransport",
		"websocket",
		"polyfill",
		"quic",
		"streams"
	]
}
