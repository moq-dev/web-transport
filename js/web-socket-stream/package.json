{
	"name": "@moq/web-socket-stream",
	"author": "Luke Curley <kixelated@gmail.com>",
	"version": "0.1.0",
	"description": "A WebSocketStream polyfill: a plain WebSocket wrapped as { readable, writable } streams with backpressure",
	"type": "module",
	"license": "(MIT OR Apache-2.0)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moq-dev/web-transport.git"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"types": "./src/index.ts",
	"files": [
		"./src"
	],
	"scripts": {
		"build": "rimraf dist && tsc && tsx ../common/package.ts",
		"dev": "tsc --watch",
		"check": "tsc --noEmit",
		"release": "bun ../common/release.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.0",
		"rimraf": "^6.1.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"keywords": [
		"websocketstream",
		"websocket",
		"polyfill",
		"ponyfill",
		"streams",
		"backpressure"
	]
}
